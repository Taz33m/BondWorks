# App
APP_ENV=local
BACKEND_PORT=8080
FRONTEND_PORT=5173

# Auth
JWT_SECRET=replace-with-local-dev-secret
BONDWORKS_DEMO_API_KEY=demo-bondworks-local-key

# Database
POSTGRES_DB=bondworks
POSTGRES_USER=bondworks
POSTGRES_PASSWORD=bondworks
DATABASE_URL=jdbc:postgresql://localhost:5432/bondworks

# Redis
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# Redpanda / Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:19092

# Frontend
VITE_API_BASE_URL=http://localhost:8080
VITE_WS_URL=ws://localhost:8080/ws

# Optional real-data APIs
# Do not commit real keys. Put them in your local .env only.
FRED_API_KEY=
OPENFIGI_API_KEY=
FINRA_CLIENT_ID=
FINRA_CLIENT_SECRET=

# Optional LLM / market color generation
OPENROUTER_API_KEY=
OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# Optional local LLM
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:1.7b
